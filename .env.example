# ── Deployment ──────────────────────────────────────────────
DEPLOYMENT_MODE=local          # local | server

# ── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_MODEL=claude-sonnet-4-6

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Database ─────────────────────────────────────────────────
# local  → sqlite+aiosqlite:///./data/studio.db
# server → postgresql+asyncpg://user:pass@host:5432/studio
DATABASE_URL=sqlite+aiosqlite:///./data/studio.db

# ── Vector DB ────────────────────────────────────────────────
VECTOR_DB_TYPE=chroma          # chroma | qdrant
CHROMA_PATH=./data/chroma
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Projects ─────────────────────────────────────────────────
PROJECTS_BASE_PATH=./projects

# ── Credits ──────────────────────────────────────────────────
CREDITS_TOTAL=1000
MAX_TOKENS_PER_TASK=8000
MAX_TOKENS_PER_PROJECT=100000

# ── Tool APIs ────────────────────────────────────────────────
UXPILOT_API_KEY=
FIGMA_API_KEY=
NOTION_API_KEY=
GOOGLE_DRIVE_CREDENTIALS_PATH=
